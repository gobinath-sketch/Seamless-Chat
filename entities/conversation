{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the conversation"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of the last message"
    },
    "message_count": {
      "type": "number",
      "default": 0,
      "description": "Number of messages in this conversation"
    }
  },
  "required": [
    "title"
  ]
}